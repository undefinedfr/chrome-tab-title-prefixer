{
  "manifest_version": 3,
  "name": "Localhost Title Prefix (dev)",
  "version": "1.1.0",
  "description": "Ajoute des préfixes configurables dans le <title> des pages selon des règles sur le hostname.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "all_frames": false,
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Localhost Title Prefix — configurer"
  }
}
